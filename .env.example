# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
BROWSER_USE_API_KEY=

# Browser Use solver (optional, host browser)
# Leave executable path empty to auto-detect google-chrome/chromium.
BROWSER_USE_EXECUTABLE_PATH=
BROWSER_USE_HEADLESS=true
